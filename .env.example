# Solana network used by wallet adapter. Keep as devnet for hackathon demos.
NEXT_PUBLIC_WALLET_ADAPTER_NETWORK=devnet

# Optional custom RPC URL. If omitted, clusterApiUrl("devnet") is used.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional key for Solana Agent Kit tools and future LLM integrations.
OPENAI_API_KEY=

# Optional Groq API key to enable real LLM reasoning in agent chat runtime.
GROQ_API_KEY=

# Required for true Bubblegum cNFT minting from Forge.
# Merkle tree address configured for your Bubblegum setup.
NEXT_PUBLIC_BUBBLEGUM_MERKLE_TREE=

# Collection mint address used by Bubblegum mint-to-collection.
NEXT_PUBLIC_BUBBLEGUM_COLLECTION_MINT=

# MongoDB connection string for persistent data storage.
# Get a free cluster at https://mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# ImageKit configuration for cNFT storage
# Get your keys at https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-imagekit-id/
