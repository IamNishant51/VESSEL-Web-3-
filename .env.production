# Solana Network
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_WALLET_ADAPTER_NETWORK=devnet

# Dev Mode (set to false for production)
NEXT_PUBLIC_DEV_MODE=false

# Bubblegum cNFT configuration
NEXT_PUBLIC_BUBBLEGUM_MERKLE_TREE=9omQw8dPEJNzZFdUBTgBQW7mPU5txJ4yxKmVN6CdL6bg
NEXT_PUBLIC_BUBBLEGUM_COLLECTION_MINT=8VCwymkAHViJsuyDzDsdJiAAcPQKRFgZhC8uHCuhWPPW

# AI / LLM (REQUIRED - get from groq.ai)
GROQ_API_KEY=your_groq_api_key_here

# Web Search (OPTIONAL - works with fallback without this)
# Get from exa.ai
EXA_API_KEY=your_exa_api_key_here

# Billing (OPTIONAL - leave empty if not using)
# Get from stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MongoDB (OPTIONAL - leave empty for local-only mode)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=

# ImageKit (OPTIONAL - leave empty if not using cNFT images)
# Get from imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
